<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reference template for the loop background scheduler LaunchAgent.

  This file documents the plist that src/main/launchd.ts generates at runtime via
  buildPlistXml(). The actual installed plist is written to
  ~/Library/LaunchAgents/com.loop.routines.daemon.plist with these placeholders filled:

    {{LABEL}}         com.loop.routines.daemon
    {{ELECTRON_PATH}} process.execPath (the Electron binary)
    {{DAEMON_SCRIPT}} <app path>/out/main/daemon.js
    {{LOG_PATH}}      ~/Library/Application Support/loop/daemon.log

  The daemon runs as plain Node via the Electron binary (ELECTRON_RUN_AS_NODE=1) so it
  shares the app runtime but does not boot the full Electron app. RunAtLoad + KeepAlive
  keep it alive across logins and crashes so routines fire even when the app is quit.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>{{LABEL}}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ELECTRON_PATH}}</string>
    <string>{{DAEMON_SCRIPT}}</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>ELECTRON_RUN_AS_NODE</key>
    <string>1</string>
    <key>PATH</key>
    <string>/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/opt/homebrew/bin:~/.local/bin</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{LOG_PATH}}</string>
  <key>StandardErrorPath</key>
  <string>{{LOG_PATH}}</string>
</dict>
</plist>
